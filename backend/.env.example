# Backend Environment Variables
# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# ===========================================
# DATABASE - MongoDB Atlas
# ===========================================
# Production: Use MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
# Development: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/dainik-rojgar

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# FIREBASE SMS OTP CONFIGURATION
# ===========================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# ===========================================
# API CONFIGURATION
# ===========================================
API_URL=http://localhost:5000

# ===========================================
# CORS - Frontend URLs
# ===========================================
FRONTEND_URL=http://localhost:19000

# Allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:19000,http://localhost:19002,exp://192.168.1.100:19000

# ===========================================
# RATE LIMITING
# ===========================================
OTP_RATE_LIMIT=5
OTP_EXPIRY_MINUTES=10
